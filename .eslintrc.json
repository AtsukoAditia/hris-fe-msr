{
  "root": true,
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "plugin:react/recommended",
    "plugin:react-hooks/recommended"
  ],
  "ignorePatterns": [
    "dist",
    "dev-dist",
    "node_modules"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "react/prop-types": "off",
    "no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_"
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "src/pages/leave/LeaveMasterPage.jsx",
        "src/hooks/useAuth.js",
        "src/pages/attendance/AttendancePage.jsx",
        "src/pages/dashboard/DashboardPage.jsx",
        "src/pages/shift-schedule/ShiftSchedulePage.jsx",
        "src/pages/shift/ShiftPage.jsx"
      ],
      "rules": {
        "react-hooks/exhaustive-deps": "off"
      }
    }
  ]
}
