# ============================================================
# HRIS MSR - Frontend Environment Variables
# Copy file ini ke .env lalu isi nilainya
# cp .env.example .env
# ============================================================

# ---- API Base URL ----
# URL backend Laravel (XAMPP: port 80 default, atau 8000 jika pakai artisan serve)
# Pastikan Apache XAMPP sudah running
VITE_API_BASE_URL=http://localhost:8000/api

# ---- App Info ----
VITE_APP_NAME="HRIS MSR"
VITE_APP_VERSION=1.0.0

# ---- Pusher / Laravel Echo (Realtime Notification) ----
# Daftar gratis di https://pusher.com -> Create App -> dapatkan credentials
# Untuk development lokal bisa skip dulu (fitur notif tidak aktif)
VITE_PUSHER_APP_KEY=your_pusher_app_key
VITE_PUSHER_APP_CLUSTER=ap1
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https

# ---- Maps / Geolocation (optional) ----
VITE_GOOGLE_MAPS_API_KEY=

# ---- Feature Flags ----
VITE_ENABLE_FACE_RECOGNITION=false
VITE_ENABLE_QR_ATTENDANCE=true

# ============================================================
# CATATAN SETUP BACKEND (hris-be-msr) dengan XAMPP + MySQL
# ============================================================
#
# 1. Pastikan XAMPP sudah install & Apache + MySQL running
#
# 2. Clone backend:
#    git clone https://github.com/AtsukoAditia/hris-be-msr.git
#    cd hris-be-msr
#
# 3. Copy & isi .env backend:
#    cp .env.example .env
#
# 4. Konfigurasi DB di .env backend Laravel:
#    DB_CONNECTION=mysql
#    DB_HOST=127.0.0.1
#    DB_PORT=3306
#    DB_DATABASE=hris_msr
#    DB_USERNAME=root
#    DB_PASSWORD=           <- kosong jika XAMPP default
#
# 5. Buat database di phpMyAdmin:
#    Buka http://localhost/phpmyadmin
#    -> New -> Nama database: hris_msr -> Create
#
# 6. Install & setup backend:
#    composer install
#    php artisan key:generate
#    php artisan migrate --seed
#    php artisan serve         <- running di localhost:8000
#
# 7. Frontend:
#    npm install
#    npm run dev               <- running di localhost:5173
# ============================================================
