# ============================================================
# HRIS MSR - Frontend Environment Variables
# Copy this file to .env and fill in the values
# cp .env.example .env
# ============================================================

# ---- API Base URL ----
# URL backend Laravel API (tanpa trailing slash)
VITE_API_BASE_URL=http://localhost:8000/api

# ---- Pusher / Laravel Echo ----
# Dapatkan dari dashboard Pusher.com atau konfigurasi Reverb
VITE_PUSHER_APP_KEY=your_pusher_app_key
VITE_PUSHER_APP_CLUSTER=ap1
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https

# ---- App Info ----
VITE_APP_NAME="HRIS MSR"
VITE_APP_VERSION=1.0.0

# ---- Maps / Geolocation (optional) ----
# Jika menggunakan Google Maps API untuk validasi lokasi
VITE_GOOGLE_MAPS_API_KEY=

# ---- Feature Flags (optional) ----
# Enable/disable fitur tertentu
VITE_ENABLE_FACE_RECOGNITION=false
VITE_ENABLE_QR_ATTENDANCE=true
